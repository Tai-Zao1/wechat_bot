# Copy this file to .env and fill in deployment-specific values.
# Never commit .env.

# local/dev/prod; controls which suffixed URL variables are preferred.
PYWECHAT_ENV=prod

# Primary API base URL.
PYWECHAT_API_BASE_URL=https://example.com/api

# Optional checkOnline base URL. Defaults to PYWECHAT_API_BASE_URL when omitted.
PYWECHAT_CHECK_ONLINE_BASE_URL=https://example.com/api

# Chat reply mode: api, local, or rules.
# api   = use backend /autoWx/chat.
# local = use local Ali Bailian application.
# rules = use keyword/default local rules only.
PYWECHAT_CHAT_MODE=api

# Local Ali Bailian settings. Keep real values only in .env or GUI local settings.
PYWECHAT_BAILIAN_APP_ID=
PYWECHAT_BAILIAN_API_KEY=
PYWECHAT_BAILIAN_TIMEOUT=20
PYWECHAT_BAILIAN_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/apps/{app_id}/completion
PYWECHAT_BAILIAN_SYSTEM=你是微信自动回复助手。请用简短、礼貌、自然的中文直接回复用户消息，不要解释你是模型。
