# Copy this file to .env and fill in deployment-specific values.
# Never commit .env.

# local/dev/prod; controls which suffixed URL variables are preferred.
PYWECHAT_ENV=prod

# Primary API base URL.
PYWECHAT_API_BASE_URL=https://example.com/api

# Optional checkOnline base URL. Defaults to PYWECHAT_API_BASE_URL when omitted.
PYWECHAT_CHECK_ONLINE_BASE_URL=https://example.com/api
